PORT=3001
API_URL=https://api.executivecad.buildablelabs.dev
WEB_URL=https://executivecad.buildablelabs.dev

# Discord OAuth2 — https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_GUILD_ID=

# Firebase Admin SDK — Service Account JSON key fields
FIREBASE_PROJECT_ID=executive-state-cad
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@executive-state-cad.iam.gserviceaccount.com
# Paste the private_key value from the service account JSON (including -----BEGIN/END-----)
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
