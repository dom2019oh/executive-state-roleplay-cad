rules_version = '2';

// Executive State CAD — Firestore Security Rules
//
// All mutating writes originate from the backend API running with a Firebase
// Admin service account, which bypasses these rules entirely.  The rules below
// therefore focus on client-side READ restrictions so that only authenticated
// Discord guild members can query data.
//
// Shorthand helpers
//   isSignedIn()     — any authenticated Firebase user
//   isGuildMember()  — authenticated AND their users/{uid} doc has guildMember == true
//   isOfficer()      — guild member whose role is "officer" or "admin"
//   isAdmin()        — guild member whose role is "admin"

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isGuildMember() {
      return isSignedIn() && userDoc().guildMember == true;
    }

    function isOfficer() {
      return isGuildMember() && userDoc().role in ['officer', 'admin'];
    }

    function isAdmin() {
      return isGuildMember() && userDoc().role == 'admin';
    }

    function isOwn(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── users ─────────────────────────────────────────────────────────────────
    // Read:  own document, or officers/admins can read any user
    // Write: service account only (client writes denied)

    match /users/{uid} {
      allow read: if isOwn(uid) || isOfficer();
      allow write: if false; // service account bypasses rules
    }

    // ── civilians ─────────────────────────────────────────────────────────────
    // Read:  any verified guild member
    // Write: service account only

    match /civilians/{docId} {
      allow read: if isGuildMember();
      allow write: if false;
    }

    // ── vehicles ─────────────────────────────────────────────────────────────
    // Read:  any verified guild member
    // Write: service account only

    match /vehicles/{docId} {
      allow read: if isGuildMember();
      allow write: if false;
    }

    // ── officers ─────────────────────────────────────────────────────────────
    match /officers/{docId} {
      allow read: if isGuildMember();
      allow write: if false;
    }

    // ── active_units ─────────────────────────────────────────────────────────
    match /active_units/{docId} {
      allow read: if isGuildMember();
      allow write: if false;
    }

    // ── calls ─────────────────────────────────────────────────────────────────
    match /calls/{docId} {
      allow read: if isGuildMember();
      allow write: if false;
    }

    // ── incidents ────────────────────────────────────────────────────────────
    match /incidents/{docId} {
      allow read: if isGuildMember();
      allow write: if false;
    }

    // ── arrests ──────────────────────────────────────────────────────────────
    match /arrests/{docId} {
      allow read: if isGuildMember();
      allow write: if false;
    }

    // ── citations ────────────────────────────────────────────────────────────
    match /citations/{docId} {
      allow read: if isGuildMember();
      allow write: if false;
    }

    // ── warrants ─────────────────────────────────────────────────────────────
    match /warrants/{docId} {
      allow read: if isGuildMember();
      allow write: if false;
    }

    // ── bolos ────────────────────────────────────────────────────────────────
    match /bolos/{docId} {
      allow read: if isGuildMember();
      allow write: if false;
    }

    // ── penal_codes ──────────────────────────────────────────────────────────
    // Read:  any guild member (officers need to look codes up during RP)
    // Write: admin only (via client — but prefer using the backend/seed script)

    match /penal_codes/{docId} {
      allow read: if isGuildMember();
      allow write: if isAdmin();
    }

    // ── ten_codes ────────────────────────────────────────────────────────────
    match /ten_codes/{docId} {
      allow read: if isGuildMember();
      allow write: if isAdmin();
    }

    // ── system_config ────────────────────────────────────────────────────────
    match /system_config/{docId} {
      allow read: if isGuildMember();
      allow write: if isAdmin();
    }

    // ── audit_log ────────────────────────────────────────────────────────────
    // Sensitive — admin read only; writes from service account only

    match /audit_log/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── dispatch_log ─────────────────────────────────────────────────────────
    match /dispatch_log/{docId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // ── Deny everything else ─────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
